# Root env (secrets) – use .env.example as template
.env
.env.local
.env.*.local

# Dependencies and build outputs
/node_modules/
/backend/node_modules/
/backend/backend/
/backend/dist/
/backend/projects/
/backend/uploads/
/backend/screenshots
/frontend/node_modules/
/frontend/build/
/launchpad-frontend/node_modules/
/launchpad-frontend/build/

# Env files (secrets) – .env.example is tracked for reference
/backend/.env
/frontend/.env
/launchpad-frontend/.env

# Runtime preview (switch version) – recreated on demand
/backend/_preview/

# --- Tracked for deployment (do not ignore): ---
# docker-compose.yml, Dockerfile(s), entrypoint.sh, nginx-configs/, nginx-frontend.conf,
# DOCKER_DEPLOYMENT.md, INSTANCE_SETUP.md, .env.example