# Copy to backend/.env — used for `cd backend && npm start` or `npm run dev:ngrok`
# The app also loads repo root `.env` first, then overrides with this file (see backend/src/app.js).

# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zipsync
# JWT_SECRET=
# BASE_URL=http://localhost:5000
# PORT=5000

# ---------- SCM push webhooks (Launchpad gitRepoPath) ----------
# Same variables as repo root `.env.example`. Resolution: NGROK_URL → FRONTEND_URL → VITE_FRONTEND_URL → BASE_URL (see backend/src/utils/apiPublicBaseUrl.js).
# GITHUB_PUSH_WEBHOOK_SECRET=
# BITBUCKET_PUSH_WEBHOOK_SECRET=

# Local webhook testing only (never commit real values):
# NGROK_AUTHTOKEN=
# NGROK_URL=
