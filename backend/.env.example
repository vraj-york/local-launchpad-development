# Copy to backend/.env — used for `cd backend && npm start` or `npm run dev:ngrok`
# The app also loads repo root `.env` first, then overrides with this file (see backend/src/app.js).

# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zipsync
# JWT_SECRET=
# BASE_URL=http://localhost:5000
# PORT=5000

# ---------- SCM push webhooks (Launchpad gitRepoPath) ----------
# Same variables as repo root `.env.example`. Resolution: NGROK_URL → FRONTEND_URL → VITE_FRONTEND_URL → BASE_URL (see backend/src/utils/apiPublicBaseUrl.js).
# GITHUB_PUSH_WEBHOOK_SECRET=
# BITBUCKET_PUSH_WEBHOOK_SECRET=

# Local webhook testing only (never commit real values):
# NGROK_AUTHTOKEN=
# NGROK_URL=

# ---------- Figma REST OAuth (Integrations) ----------
# Register callback on https://www.figma.com/developers/apps — must match REDIRECT_URI exactly.
# FIGMA_OAUTH_CLIENT_ID=
# FIGMA_OAUTH_CLIENT_SECRET=
# FIGMA_OAUTH_REDIRECT_URI=http://localhost:5000/api/integrations/figma/callback
# Optional: override default scopes (space-separated). Default in code includes current_user:read, files,
# design-system library reads, dev resources, projects:read, webhooks read/write — see DEFAULT_FIGMA_OAUTH_SCOPES in oauth.routes.js
# FIGMA_OAUTH_SCOPES=current_user:read file_content:read
