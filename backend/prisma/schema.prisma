generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role
  projectsCreated      Project[] @relation("CreatedProjects")
  projectsManaged      Project[] @relation("ManagedProjects")
  projectAccess        ProjectAccess[]
  versionsUploaded     ProjectVersion[] @relation("VersionUploader")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id                Int      @id @default(autoincrement())
  name              String
  description       String?
  createdById       Int
  assignedManagerId Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  createdBy         User     @relation("CreatedProjects", fields: [createdById], references: [id])
  assignedManager   User     @relation("ManagedProjects", fields: [assignedManagerId], references: [id])
  projectAccess     ProjectAccess[]
  versions          ProjectVersion[]
}

model ProjectAccess {
  id        Int      @id @default(autoincrement())
  project   Project  @relation(fields: [projectId], references: [id])
  projectId Int
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  createdAt DateTime @default(now())
}

model ProjectVersion {
  id          Int      @id @default(autoincrement())
  projectId   Int
  version     String   // e.g., "1.0.0", "1.1.0", "2.0.0"
  zipFilePath String
  buildUrl    String
  isActive    Boolean  @default(false) // Only one version can be active per project
  uploadedBy  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploader    User     @relation("VersionUploader", fields: [uploadedBy], references: [id])
}

enum Role {
  admin
  manager
  client
}