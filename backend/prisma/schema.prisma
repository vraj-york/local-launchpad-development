generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role
  projectsCreated      Project[] @relation("CreatedProjects")
  projectsManaged      Project[] @relation("ManagedProjects")
  versionsUploaded     ProjectVersion[] @relation("VersionUploader")
  releasesCreated       Release[]       @relation("ReleaseCreator")
  releaseChangeLogs     ReleaseChangeLog[]
  figmaConversions     FigmaConversion[] @relation("FigmaConversionAttemptedBy")
  oauthConnections     UserOAuthConnection[]
  image    String?  

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum OAuthProvider {
  github
  jira_atlassian
  bitbucket
}

/// Multiple OAuth connections per user per provider; projects pick a specific connection id.
model UserOAuthConnection {
  id                     Int            @id @default(autoincrement())
  userId                 Int
  provider               OAuthProvider
  /// Optional user-defined label in UI (e.g. "Work GitHub").
  label                  String?
  encryptedAccessToken   String         @db.Text
  encryptedRefreshToken  String         @db.Text
  accessTokenExpiresAt   DateTime?
  githubLogin            String?
  /// Bitbucket Cloud account UUID (dedupe on OAuth reconnect).
  bitbucketUuid          String?
  bitbucketUsername      String?
  jiraBaseUrl            String?
  atlassianAccountEmail  String?
  atlassianCloudId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectsGithub  Project[] @relation("ProjectGithubConnection")
  projectsBitbucket Project[] @relation("ProjectBitbucketConnection")
  projectsJira    Project[] @relation("ProjectJiraConnection")

  @@index([userId])
  @@index([userId, provider])
}

model Project {
  id                Int      @id @default(autoincrement())
  name              String
  /// Optional URL-safe slug (derived from project name in app). Nullable so `prisma db push` works on DBs with existing rows.
  slug              String?  @unique
  description       String?
  createdById       Int
  assignedManagerId Int
  isUploading  Boolean  @default(false)
  
  githubUsername   String?
  githubToken      String?
  bitbucketUsername String?
  bitbucketToken   String?

  jiraBaseUrl      String?
  jiraProjectKey   String?
  jiraApiToken  String?
  jiraUsername    String?
  jiraIssueType    String?
  
  port              Int?     @unique
  projectPath       String?
  gitRepoPath       String?
  /// Optional customer/development repo (GitHub/Bitbucket). On release lock, platform source is synced as a submodule at this tag.
  developmentRepoUrl  String?
  nginxConfigPath   String?
  projectId String?  
  /// Optional comma-separated list of assignee emails (external / hub); validated as emails.
  assignedUserEmails  String?
  /// Optional comma-separated stakeholder emails; public release lock only allowed for these addresses.
  stakeholderEmails   String?

  githubConnectionId   Int?
  bitbucketConnectionId Int?
  jiraConnectionId   Int?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  createdBy         User     @relation("CreatedProjects", fields: [createdById], references: [id])
  assignedManager   User     @relation("ManagedProjects", fields: [assignedManagerId], references: [id])
  githubConnection  UserOAuthConnection? @relation("ProjectGithubConnection", fields: [githubConnectionId], references: [id], onDelete: SetNull)
  bitbucketConnection UserOAuthConnection? @relation("ProjectBitbucketConnection", fields: [bitbucketConnectionId], references: [id], onDelete: SetNull)
  jiraConnection    UserOAuthConnection? @relation("ProjectJiraConnection", fields: [jiraConnectionId], references: [id], onDelete: SetNull)
  versions          ProjectVersion[]
  releases          Release[]
  roadmaps          Roadmap[]
  figmaConversions  FigmaConversion[]
  chatHistory ChatHistory[]

}

model ProjectVersion {
  id          Int      @id @default(autoincrement())
  projectId   Int
  releaseId   Int?     // Link to release (optional for backward compatibility)
  version     String   // e.g., "1.0.0", "1.1.0", "2.0.0"
  zipFilePath String?   // Legacy column; kept to avoid data loss. App uses gitTag only—write same value as gitTag when creating.
  gitTag      String   // Git tag / ref for checkout & activate (primary)
  buildUrl    String
  isActive    Boolean  @default(false) // Only one version can be active per project
  uploadedBy  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  release     Release? @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  uploader    User     @relation("VersionUploader", fields: [uploadedBy], references: [id])
  figmaConversions FigmaConversion[]


}



enum ReleaseStatus {
  draft
  active
  locked
  skip
}

model Release {
  id          Int      @id @default(autoincrement())
  projectId   Int
  name        String
  description String?
  /// Planned ship / target date (timeline).
  releaseDate DateTime?
  /// When the release actually shipped (vs planned releaseDate).
  actualReleaseDate DateTime?
  /// Optional notes when recording actual ship (internal / roadmap).
  actualReleaseNotes String? @db.Text
  /// Planned start date (timeline).
  startDate   DateTime?
  status      ReleaseStatus @default(draft)
  isMvp       Boolean  @default(false)
  /// Email of the user who locked via the public lock API (set only when status is locked).
  lockedBy    String?
  /// Optional notes for stakeholders on the client link (e.g. what not to test, scope).
  clientReleaseNote    String?

  createdBy   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator     User            @relation("ReleaseCreator", fields: [createdBy], references: [id])
  versions    ProjectVersion[]
  figmaConversions FigmaConversion[]
  changeLogs  ReleaseChangeLog[]
  chatHistory ChatHistory[]


}

model ReleaseChangeLog {
  id              Int      @id @default(autoincrement())
  releaseId       Int
  reason          String
  changedById     Int?
  changedByEmail  String?
  changes         Json
  createdAt       DateTime @default(now())

  release   Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  changedBy User?   @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([releaseId, createdAt])
}

model FigmaConversion {
  id                Int      @id @default(autoincrement())
  projectId         Int
  releaseId         Int
  agentId           String
  attemptedById    Int
  attemptedAt      DateTime @default(now())
  attemptNumber    Int?
  nodeCount        Int?
  status           String?
  targetBranchName String?
  projectVersionId Int?
  /// User chat message waiting for this agent turn's commit SHA.
  pendingClientChatMessageId Int?
  /// When true (client-link flows), agent FINISHED does not auto-merge; user must confirm.
  deferLaunchpadMerge           Boolean  @default(false)
  awaitingLaunchpadConfirmation Boolean  @default(false)
  /// When true (e.g. post-lock developer-repo agent), poller does not merge to platform launchpad.
  skipLaunchpadAutomation       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  release        Release         @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  attemptedBy    User            @relation("FigmaConversionAttemptedBy", fields: [attemptedById], references: [id])
  projectVersion ProjectVersion? @relation(fields: [projectVersionId], references: [id], onDelete: SetNull)
}

/// Public client-link chat history per release (persists across sessions).
model ChatHistory {
  id        Int      @id @default(autoincrement())
  projectId Int
  releaseId Int
  role      String
  text      String   @db.Text
  appliedCommitSha String?
  mergedAt  DateTime?
  revertedAt       DateTime?
  revertCommitSha  String?
  /// When false, row is kept for audit but omitted from the client-link chat panel.
  isActiveChat     Boolean  @default(true)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  release Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@index([projectId, releaseId, createdAt])
  @@index([projectId, releaseId, isActiveChat])
  @@index([projectId, releaseId, appliedCommitSha])
}


enum Role {
  admin
  manager

}
model Roadmap {
  id            Int       @id @default(autoincrement())
  projectId     Int

  title         String
  description   String?
  status        RoadmapStatus @default(DRAFT)
  tshirtSize    TshirtSize    @default(M)

  timelineStart DateTime
  timelineEnd   DateTime

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items         RoadmapItem[]
}

model RoadmapItem {
  id          Int       @id @default(autoincrement())
  roadmapId   Int
  releaseId   Int?      // 🔥 optional


  title       String
  description String?
  type        RoadmapItemType     @default(FEATURE)
  status      RoadmapItemStatus   @default(PLANNED)
  priority    RoadmapItemPriority @default(MEDIUM)

  startDate   DateTime
  endDate     DateTime

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  roadmap     Roadmap   @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
}

enum RoadmapStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TshirtSize {
  XS
  S
  M
  L
  XL
}

enum RoadmapItemType {
  FEATURE
  EPIC
  INITIATIVE
  TECH_DEBT
  BUG
  IMPROVEMENT
  
}

enum RoadmapItemStatus {
  PLANNED
  IN_PROGRESS
  DONE
  BLOCKED
  DRAFT
  ACTIVE
  COMPLETED
}

enum RoadmapItemPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}
