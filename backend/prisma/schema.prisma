generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role
  projectsCreated      Project[] @relation("CreatedProjects")
  projectsManaged      Project[] @relation("ManagedProjects")
  projectAccess        ProjectAccess[]
  versionsUploaded     ProjectVersion[] @relation("VersionUploader")
  releasesCreated       Release[]       @relation("ReleaseCreator")
  releaseChangeLogs     ReleaseChangeLog[]
  figmaConversions     FigmaConversion[] @relation("FigmaConversionAttemptedBy")
  image    String?  

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id                Int      @id @default(autoincrement())
  name              String
  /// Optional URL-safe slug (derived from project name in app). Nullable so `prisma db push` works on DBs with existing rows.
  slug              String?  @unique
  description       String?
  createdById       Int
  assignedManagerId Int
  isUploading  Boolean  @default(false)
  
  githubUsername   String?
  githubToken      String?

  jiraBaseUrl      String?
  jiraProjectKey   String?
  jiraApiToken  String?
  jiraUsername    String?
  jiraIssueType    String?
  
  port              Int?     @unique
  projectPath       String?
  gitRepoPath       String?
  nginxConfigPath   String?
  projectId String?  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  createdBy         User     @relation("CreatedProjects", fields: [createdById], references: [id])
  assignedManager   User     @relation("ManagedProjects", fields: [assignedManagerId], references: [id])
  projectAccess     ProjectAccess[]
  versions          ProjectVersion[]
  releases          Release[]
  roadmaps          Roadmap[]
    figmaConversions  FigmaConversion[]

}

model ProjectAccess {
  id        Int      @id @default(autoincrement())
  project   Project  @relation(fields: [projectId], references: [id])
  projectId Int
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  createdAt DateTime @default(now())
}

model ProjectVersion {
  id          Int      @id @default(autoincrement())
  projectId   Int
  releaseId   Int?     // Link to release (optional for backward compatibility)
  version     String   // e.g., "1.0.0", "1.1.0", "2.0.0"
  zipFilePath String?   // Legacy column; kept to avoid data loss. App uses gitTag only—write same value as gitTag when creating.
  gitTag      String   // Git tag / ref for checkout & activate (primary)
  buildUrl    String
  isActive    Boolean  @default(false) // Only one version can be active per project
  uploadedBy  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  release     Release? @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  uploader    User     @relation("VersionUploader", fields: [uploadedBy], references: [id])
  roadmapItems  RoadmapItem[] @relation("VersionRoadmapItems")
    figmaConversions FigmaConversion[]


}



enum ReleaseStatus {
  draft
  active
  locked
  skip
}

model Release {
  id          Int      @id @default(autoincrement())
  projectId   Int
  name        String
  description String?
  /// Planned ship / target date (timeline).
  releaseDate DateTime?
  /// Planned start date (timeline).
  startDate   DateTime?
  status      ReleaseStatus @default(draft)
  isMvp       Boolean  @default(false)
  /// Email of the user who locked via the public lock API (set only when status is locked).
  lockedBy    String?

  createdBy   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator     User            @relation("ReleaseCreator", fields: [createdBy], references: [id])
  versions    ProjectVersion[]
  figmaConversions FigmaConversion[]
  changeLogs  ReleaseChangeLog[]

}

model ReleaseChangeLog {
  id              Int      @id @default(autoincrement())
  releaseId       Int
  reason          String
  changedById     Int?
  changedByEmail  String?
  changes         Json
  createdAt       DateTime @default(now())

  release   Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  changedBy User?   @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([releaseId, createdAt])
}

model FigmaConversion {
  id                Int      @id @default(autoincrement())
  projectId         Int
  releaseId         Int
  agentId           String
  attemptedById    Int
  attemptedAt      DateTime @default(now())
  attemptNumber    Int?
  nodeCount        Int?
  status           String?
  targetBranchName String?
  projectVersionId Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  release        Release         @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  attemptedBy    User            @relation("FigmaConversionAttemptedBy", fields: [attemptedById], references: [id])
  projectVersion ProjectVersion? @relation(fields: [projectVersionId], references: [id], onDelete: SetNull)
}


enum Role {
  admin
  manager

}
model Roadmap {
  id            Int       @id @default(autoincrement())
  projectId     Int

  title         String
  description   String?
  status        RoadmapStatus @default(DRAFT)
  tshirtSize    TshirtSize    @default(M)

  timelineStart DateTime
  timelineEnd   DateTime

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items         RoadmapItem[]
}

model RoadmapItem {
  id          Int       @id @default(autoincrement())
  roadmapId   Int
  releaseId   Int?      // 🔥 optional


  title       String
  description String?
  type        RoadmapItemType     @default(FEATURE)
  status      RoadmapItemStatus   @default(PLANNED)
  priority    RoadmapItemPriority @default(MEDIUM)

  startDate   DateTime
  endDate     DateTime

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  roadmap     Roadmap   @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  projectVersions ProjectVersion[] @relation("VersionRoadmapItems")
  
  }

enum RoadmapStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TshirtSize {
  XS
  S
  M
  L
  XL
}

enum RoadmapItemType {
  FEATURE
  EPIC
  INITIATIVE
  TECH_DEBT
  BUG
  IMPROVEMENT
  
}

enum RoadmapItemStatus {
  PLANNED
  IN_PROGRESS
  DONE
  BLOCKED
  DRAFT
  ACTIVE
  COMPLETED
}

enum RoadmapItemPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}
