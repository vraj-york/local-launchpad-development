generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role
  projectsCreated      Project[] @relation("CreatedProjects")
  projectsManaged      Project[] @relation("ManagedProjects")
  projectAccess        ProjectAccess[]
  versionsUploaded     ProjectVersion[] @relation("VersionUploader")
  releasesCreated       Release[]       @relation("ReleaseCreator")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id                Int      @id @default(autoincrement())
  name              String
  description       String?
  createdById       Int
  assignedManagerId Int

  githubToken   String?
  jiraToken     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  createdBy         User     @relation("CreatedProjects", fields: [createdById], references: [id])
  assignedManager   User     @relation("ManagedProjects", fields: [assignedManagerId], references: [id])
  projectAccess     ProjectAccess[]
  versions          ProjectVersion[]
  releases          Release[]
  roadmaps          Roadmap[]
}

model ProjectAccess {
  id        Int      @id @default(autoincrement())
  project   Project  @relation(fields: [projectId], references: [id])
  projectId Int
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  createdAt DateTime @default(now())
}

model ProjectVersion {
  id          Int      @id @default(autoincrement())
  projectId   Int
  releaseId   Int?     // Link to release (optional for backward compatibility)
  version     String   // e.g., "1.0.0", "1.1.0", "2.0.0"
  zipFilePath String
  buildUrl    String
  isActive    Boolean  @default(false) // Only one version can be active per project
  uploadedBy  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  release     Release? @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  uploader    User     @relation("VersionUploader", fields: [uploadedBy], references: [id])
}



model Release {
  id          Int      @id @default(autoincrement())
  projectId   Int
  name        String
  description String?
  releaseDate DateTime?   // 🔥 ADD (key for timeline & roadmap)
  isLocked    Boolean  @default(false)

  createdBy   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator     User            @relation("ReleaseCreator", fields: [createdBy], references: [id])
  versions    ProjectVersion[]

  roadmapItems RoadmapItem[]  // 🔥 ADD
}


enum Role {
  admin
  manager

}
model Roadmap {
  id            Int       @id @default(autoincrement())
  projectId     Int

  title         String
  description   String?
  status        RoadmapStatus @default(DRAFT)
  tshirtSize    TshirtSize    @default(M)

  timelineStart DateTime
  timelineEnd   DateTime

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items         RoadmapItem[]
}

model RoadmapItem {
  id          Int       @id @default(autoincrement())
  roadmapId   Int
  releaseId   Int?      // 🔥 optional

  title       String
  description String?
  type        RoadmapItemType     @default(FEATURE)
  status      RoadmapItemStatus   @default(PLANNED)
  priority    RoadmapItemPriority @default(MEDIUM)

  startDate   DateTime
  endDate     DateTime

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  roadmap     Roadmap   @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  release     Release?  @relation(fields: [releaseId], references: [id])
}

enum RoadmapStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TshirtSize {
  XS
  S
  M
  L
  XL
}

enum RoadmapItemType {
  FEATURE
  EPIC
  INITIATIVE
  TECH_DEBT
}

enum RoadmapItemStatus {
  PLANNED
  IN_PROGRESS
  DONE
  BLOCKED
}

enum RoadmapItemPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}
