generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role
  projectsCreated      Project[] @relation("CreatedProjects")
  versionsUploaded     ProjectVersion[] @relation("VersionUploader")
  releasesCreated       Release[]       @relation("ReleaseCreator")
  releaseChangeLogs     ReleaseChangeLog[]
  figmaConversions     FigmaConversion[] @relation("FigmaConversionAttemptedBy")
  oauthConnections     UserOAuthConnection[]
  image    String?  

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum OAuthProvider {
  github
  jira_atlassian
  bitbucket
  figma
}

/// Multiple OAuth connections per user per provider; projects pick a specific connection id.
model UserOAuthConnection {
  id                     Int            @id @default(autoincrement())
  userId                 Int
  provider               OAuthProvider
  /// Optional user-defined label in UI (e.g. "Work GitHub").
  label                  String?
  encryptedAccessToken   String         @db.Text
  encryptedRefreshToken  String         @db.Text
  accessTokenExpiresAt   DateTime?
  githubLogin            String?
  /// Bitbucket Cloud account UUID (dedupe on OAuth reconnect).
  bitbucketUuid          String?
  bitbucketUsername      String?
  jiraBaseUrl            String?
  atlassianAccountEmail  String?
  atlassianCloudId       String?
  /// Figma REST API user id (`user_id_string` from token response); use string, not JS Number.
  figmaUserId            String?
  /// Figma display name from `GET /v1/me` (`handle`).
  figmaHandle            String?
  /// Figma account email from `GET /v1/me` (only present on that endpoint).
  figmaEmail             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectsGithub  Project[] @relation("ProjectGithubConnection")
  projectsBitbucket Project[] @relation("ProjectBitbucketConnection")
  projectsJira    Project[] @relation("ProjectJiraConnection")

  @@index([userId])
  @@index([userId, provider])
  @@index([userId, figmaUserId])
}

model Project {
  id                Int      @id @default(autoincrement())
  name              String
  /// Optional URL-safe slug (derived from project name in app). Nullable so `prisma db push` works on DBs with existing rows.
  slug              String?  @unique
  description       String?
  createdById       Int
  isUploading  Boolean  @default(false)
  
  githubUsername   String?
  githubToken      String?
  bitbucketUsername String?
  bitbucketToken   String?

  jiraBaseUrl      String?
  jiraProjectKey   String?
  jiraApiToken  String?
  jiraUsername    String?
  jiraIssueType    String?
  
  port              Int?     @unique
  projectPath       String?
  gitRepoPath       String?
  /// Optional customer/development repo (GitHub/Bitbucket). On release lock, platform source is synced as a submodule at this tag.
  developmentRepoUrl  String?
  nginxConfigPath   String?
  projectId String?  
  /// Optional comma-separated list of assignee emails (external / hub); validated as emails.
  assignedUserEmails  String?
  /// Optional comma-separated stakeholder emails; public release lock only allowed for these addresses.
  stakeholderEmails   String?
  /// Initial Cursor agent prompt when creating a project from scratch (`isScratch` flow).
  scratchPrompt         String?  @db.Text
  /// True when the project was created with `isScratch`; used to show deferred scratch UI until the first release exists.
  fromScratch           Boolean  @default(false)
  /// Last known Cursor cloud agent status for the from-scratch flow (updated by backend poller).
  scratchAgentStatus    String?
  /// Post-agent merge/tag/build phase for from-scratch projects (CREATING | FAILED | null).
  scratchVersionStatus  String?

  githubConnectionId   Int?
  bitbucketConnectionId Int?
  jiraConnectionId   Int?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  createdBy         User     @relation("CreatedProjects", fields: [createdById], references: [id])
  githubConnection  UserOAuthConnection? @relation("ProjectGithubConnection", fields: [githubConnectionId], references: [id], onDelete: SetNull)
  bitbucketConnection UserOAuthConnection? @relation("ProjectBitbucketConnection", fields: [bitbucketConnectionId], references: [id], onDelete: SetNull)
  jiraConnection    UserOAuthConnection? @relation("ProjectJiraConnection", fields: [jiraConnectionId], references: [id], onDelete: SetNull)
  versions          ProjectVersion[]
  releases          Release[]
  figmaConversions  FigmaConversion[]
  chatHistory ChatHistory[]
  feedbackRecordingSessions FeedbackRecordingSession[]
}

/// Instance-wide custom Cursor rule packs (shared across all projects; single rules.mdc per folder on import).
model CustomCursorRule {
  id         Int      @id @default(autoincrement())
  folderName String   @unique
  body       String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// Chunked screen recording for feedback widget (S3) → FFmpeg merge → Jira attachment.
model FeedbackRecordingSession {
  id                String                         @id @default(uuid())
  projectId         Int
  reporterEmail     String
  /// Opaque secret; required for chunk presign and complete endpoints.
  sessionToken      String
  status            FeedbackRecordingSessionStatus @default(uploading)
  /// Declared total chunks when client calls complete (or on feedback submit).
  chunkCount        Int?
  finalS3Key        String?
  error             String?                        @db.Text
  createdAt         DateTime                       @default(now())
  updatedAt         DateTime                       @updatedAt

  project   Project                     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mergeJobs FeedbackRecordingMergeJob[]

  @@index([projectId, createdAt])
}

enum FeedbackRecordingSessionStatus {
  uploading
  ready_for_merge
  merged
  failed
}

model FeedbackRecordingMergeJob {
  id            String                        @id @default(uuid())
  sessionId     String
  jiraIssueKey  String
  projectId     Int
  status        FeedbackRecordingMergeJobStatus @default(pending)
  attempts      Int                           @default(0)
  lockedAt      DateTime?
  lastError     String?                       @db.Text
  createdAt     DateTime                      @default(now())
  updatedAt     DateTime                      @updatedAt

  session FeedbackRecordingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

enum FeedbackRecordingMergeJobStatus {
  pending
  processing
  completed
  failed
}

model ProjectVersion {
  id          Int      @id @default(autoincrement())
  projectId   Int
  releaseId   Int?     // Link to release (optional for backward compatibility)
  version     String   // e.g., "1.0.0", "1.1.0", "2.0.0"
  gitTag      String   // Git tag / ref for checkout & activate (primary)
  buildUrl    String
  isActive    Boolean  @default(false) // Only one version can be active per project
  uploadedBy  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  release     Release? @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  uploader    User     @relation("VersionUploader", fields: [uploadedBy], references: [id])
  figmaConversions FigmaConversion[]
}


enum ReleaseStatus {
  draft
  active
  locked
  skip
}

model Release {
  id          Int      @id @default(autoincrement())
  projectId   Int
  name        String
  description String?
  /// Planned ship / target date (timeline).
  releaseDate DateTime?
  /// When the release actually shipped (vs planned releaseDate).
  actualReleaseDate DateTime?
  /// Optional notes when recording actual ship (internal / roadmap).
  actualReleaseNotes String? @db.Text
  /// Planned start date (timeline).
  startDate   DateTime?
  status      ReleaseStatus @default(draft)
  isMvp       Boolean  @default(false)
  /// Email of the user who locked via the public lock API (set only when status is locked).
  lockedBy    String?
  /// Optional notes for stakeholders on the client link (e.g. what not to test, scope).
  clientReleaseNote    String?
  /// “What to review” checklist for client link (AI-generated and/or edited manually).
  clientReviewAiSummary     String?   @db.Text
  clientReviewAiSummaryAt   DateTime?
  /// When false, client link hides the review summary even if text is set.
  showClientReviewSummary   Boolean   @default(true)
  /// Optional team notes for the AI only when generating “what to review” (not shown on client link).
  clientReviewAiGenerationContext String? @db.Text
  /// Cursor Cloud agent id for post-lock backend plan (developer integration repo).
  backendAgentId     String?
  /// Last known Cursor agent status for backend plan (polled server-side).
  backendAgentStatus String?
  /// Relative path in developer repo where platform submodule was placed at lock (default launchpad-frontend).
  developerSubmodulePath String?
  /// Git ref on developer repo for post-lock Cursor agent `source.ref` when set at lock; null uses default-branch/env/main resolution.
  developerAgentRef String?

  createdBy   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator     User            @relation("ReleaseCreator", fields: [createdBy], references: [id])
  versions    ProjectVersion[]
  figmaConversions FigmaConversion[]
  changeLogs  ReleaseChangeLog[]
  chatHistory ChatHistory[]


}

model ReleaseChangeLog {
  id              Int      @id @default(autoincrement())
  releaseId       Int
  reason          String
  changedById     Int?
  changedByEmail  String?
  changes         Json
  createdAt       DateTime @default(now())

  release   Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  changedBy User?   @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([releaseId, createdAt])
}

model FigmaConversion {
  id                Int      @id @default(autoincrement())
  projectId         Int
  releaseId         Int
  agentId           String
  attemptedById    Int
  attemptedAt      DateTime @default(now())
  attemptNumber    Int?
  nodeCount        Int?
  status           String?
  targetBranchName String?
  projectVersionId Int?
  /// User chat message waiting for this agent turn's commit SHA.
  pendingClientChatMessageId Int?
  /// When true (client-link flows), agent FINISHED does not auto-merge; user must confirm.
  deferLaunchpadMerge           Boolean  @default(false)
  awaitingLaunchpadConfirmation Boolean  @default(false)
  /// When true (e.g. post-lock developer-repo agent), poller does not merge to platform launchpad.
  skipLaunchpadAutomation       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  release        Release         @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  attemptedBy    User            @relation("FigmaConversionAttemptedBy", fields: [attemptedById], references: [id])
  projectVersion ProjectVersion? @relation(fields: [projectVersionId], references: [id], onDelete: SetNull)
  linkedChatMessages ChatHistory[]
}

/// Public client-link chat history per release (persists across sessions).
model ChatHistory {
  id        Int      @id @default(autoincrement())
  projectId Int
  releaseId Int
  role      String
  text      String   @db.Text
  appliedCommitSha String?
  mergedAt  DateTime?
  revertedAt       DateTime?
  revertCommitSha  String?
  /// When false, row is kept for audit but omitted from the client-link chat panel.
  isActiveChat     Boolean  @default(true)
  /// Stable link to the FigmaConversion / Cursor agent run for this user turn (persists after pendingClientChatMessageId is cleared on the conversion row).
  figmaConversionId Int?
  /// S3 URLs for reference (or replacement) chat images in one message (PostgreSQL text array).
  attachmentImageUrls String[] @default([])
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  release Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  figmaConversion FigmaConversion? @relation(fields: [figmaConversionId], references: [id], onDelete: SetNull)

  @@index([projectId, releaseId, createdAt])
  @@index([projectId, releaseId, isActiveChat])
  @@index([projectId, releaseId, appliedCommitSha])
  @@index([figmaConversionId])
}


enum Role {
  admin
  manager

}
