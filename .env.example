# ---------- Cursor Cloud Agents (backend) ----------
# Required for client-link chat and /api/cursor. Create a key in the Cursor dashboard.
# CURSOR_API_KEY=
# Base URL of cursor-cloud-agent (Next.js CLR). Local Node (npm run dev in backend): http://localhost:3100
# CURSOR_BASE_URL=http://localhost:3100
# Docker Compose backend ignores host CURSOR_BASE_URL for wiring; it uses CURSOR_CLOUD_AGENT_URL or defaults to
# http://cursor-cloud-agent:3100 (see docker-compose.yml). Set CURSOR_CLOUD_AGENT_URL only to override, e.g.
# CURSOR_CLOUD_AGENT_URL=http://host.docker.internal:3100
# Optional: force source.ref for Cursor agents. If unset, the ref is read from GitHub default_branch for the repo.
# CURSOR_AGENT_SOURCE_REF=main

# ---------- OpenAI (backend) — client-link “What to review” AI summary per release ----------
# Optional: without OPENAI_API_KEY, summaries are not generated (manual regenerate returns an error).
# OPENAI_API_KEY=sk-...
# Optional model (default gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# ---------- Anthropic (backend) — Client Link “AI SVG” preview (POST /api/chat/:slug/ai-preview-svg) ----------
# Uses the same key as other Anthropic features if you prefer one variable: ANTHROPIC_API_KEY is also read.
# CLAUDE_API_KEY=

# ---------- GitHub & Jira OAuth (backend) — project creation without manual PAT/API tokens ----------
# 32-byte key, base64 (generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
