# =============================================================================
# This file is for DOCKER only. Copy to .env in REPO ROOT (same folder as
# docker-compose.yml). When you run "docker compose up", only this root .env
# is used; backend and frontend containers do NOT read backend/.env or
# frontend/.env. For local dev without Docker, use backend/.env and
# frontend/.env instead. See DOCKER_DEPLOYMENT.md → "Which .env file is used?"
# =============================================================================

# ---------- Database ----------------------------------------------------------
# PRODUCTION: Use Supabase. Set DATABASE_URL to your Supabase connection string
# (Supabase Dashboard → Project Settings → Database). Do not use the db
# container or POSTGRES_* in production.
#
# Example (replace with your Supabase URI):
# DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres
#
DATABASE_URL=

# LOCAL DEV ONLY: Optional Docker DB. Uncomment and use with: docker compose --profile with-db up -d
# DATABASE_URL=postgresql://pmuser:pmsecret@db:5432/project_management
# POSTGRES_USER=pmuser
# POSTGRES_PASSWORD=pmsecret
# POSTGRES_DB=project_management

# ---------- [DOCKER ONLY] Default admin (seed on first backend start) ----------
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=admin@123

# ---------- [DOCKER] Backend env (override in docker-compose or here) ----------
# BASE_URL=http://localhost:5000
# JWT_SECRET=your-secret-key
# INSTANCE_ROOT=/app
# NGINX_BASE_DOMAIN=localhost

# ---------- [DOCKER] Project port range (ports come from DB: 8001, 8002, ...) ----------
# Last port to publish from backend (default 8100 = 8001-8100). Increase if you have many projects (e.g. 8999).
# PROJECT_PORT_END=8100

# ---------- [DOCKER ONLY] Frontend build args (baked at image build) ----------
VITE_API_URL=http://localhost:5000
VITE_FRONTEND_URL=http://localhost:3000
