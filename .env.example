# Repo root — used by `docker compose` only. Local dev without Docker: `backend/.env` + `frontend/.env`.
# Optional overrides: `.env.local` (gitignored). Full optional keys: `docker-compose.yml` → `backend.environment` / `frontend.build.args`.

# --- Core (set for every environment) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zipsync
JWT_SECRET=change-me-in-development-only
BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# --- Frontend image build (rebuild frontend image after changes) ---
VITE_API_URL=http://localhost:5000
VITE_FRONTEND_URL=http://localhost:3000
# VITE_MODE=production
# VITE_HUB_API_URL=
# VITE_HUB_OAUTH_REDIRECT_URL=
# VITE_HUB_PROFILE_PIC_API_KEY=

# --- HTTPS / nginx (production-style deploy) ---
# NGINX_BASE_DOMAIN=example.com
# SSL_DOMAIN=app.example.com

# --- Local Postgres container (`docker compose --profile with-db`) ---
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=zipsync

# --- First-run seed (optional) ---
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=admin123

# --- Cognito (Hub token exchange) ---
# AWS_COGNITO_USER_POOL_ID=
# AWS_COGNITO_APP_CLIENT_ID=
# AUTH_ALLOWED_DOMAIN=

# --- Cursor Cloud Agents (backend) ---
# Required for client-link chat and /api/cursor. Create a key in the Cursor dashboard.
# CURSOR_API_KEY=
# Base URL of cursor-cloud-agent (Next.js CLR). Local Node (npm run dev in backend): http://localhost:3100
# CURSOR_BASE_URL=http://localhost:3100
# Docker Compose backend ignores host CURSOR_BASE_URL for wiring; it uses CURSOR_CLOUD_AGENT_URL or defaults to
# http://cursor-cloud-agent:3100 (see docker-compose.yml). Set CURSOR_CLOUD_AGENT_URL only to override, e.g.
# CURSOR_CLOUD_AGENT_URL=http://host.docker.internal:3100
# Optional: force source.ref for Cursor agents. If unset, the ref is read from GitHub default_branch for the repo.
# CURSOR_AGENT_SOURCE_REF=main

# --- OpenAI (backend) — client-link “What to review” AI summary per release ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Anthropic (backend) — Client Link “AI SVG” preview ---
# CLAUDE_API_KEY=

# --- OAuth token storage + providers (redirect URIs must match your API host) ---
# 32-byte key, base64 (generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
# OAUTH_TOKEN_ENCRYPTION_KEY=
# OAUTH_STATE_SECRET=
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_REDIRECT_URI=http://localhost:5000/api/integrations/github/callback
# ATLASSIAN_OAUTH_CLIENT_ID=
# ATLASSIAN_OAUTH_CLIENT_SECRET=
# ATLASSIAN_OAUTH_REDIRECT_URI=http://localhost:5000/api/integrations/jira/callback
# BITBUCKET_OAUTH_CLIENT_ID=
# BITBUCKET_OAUTH_CLIENT_SECRET=
# BITBUCKET_OAUTH_REDIRECT_URI=http://localhost:5000/api/integrations/bitbucket/callback
# Optional: BITBUCKET_OAUTH_SCOPES=account repository webhook
#
# Figma REST API OAuth (backend) — register the same callback URL on the OAuth app at figma.com/developers/apps
# FIGMA_OAUTH_CLIENT_ID=
# FIGMA_OAUTH_CLIENT_SECRET=
# FIGMA_OAUTH_REDIRECT_URI=http://localhost:5000/api/integrations/figma/callback
# Optional: override default Figma OAuth scopes (space-separated). Server default lists user, files, comments,
# libraries, dev resources, projects, webhooks — see DEFAULT_FIGMA_OAUTH_SCOPES in backend/src/routes/oauth.routes.js
# FIGMA_OAUTH_SCOPES=current_user:read file_content:read

# --- SCM push webhooks (Launchpad gitRepoPath — backend) ---
# GITHUB_PUSH_WEBHOOK_SECRET=
# BITBUCKET_PUSH_WEBHOOK_SECRET=
# Local webhook testing only (do not set in production; never commit real tokens):
# NGROK_AUTHTOKEN=
# NGROK_URL=

# --- S3 uploads / screen recording worker / presign ---
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=

# --- Preview port range (defaults 8001–8100) ---
# PROJECT_PORT_END=8100
