# Repo root — used by `docker compose` only. Local dev without Docker: `backend/.env` + `frontend/.env`.
# Optional overrides: `.env.local` (gitignored). Full optional keys: `docker-compose.yml` → `backend.environment` / `frontend.build.args`.

# --- Core (set for every environment) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zipsync
JWT_SECRET=change-me-in-development-only
BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# --- Frontend image build (rebuild frontend image after changes) ---
VITE_API_URL=http://localhost:5000
VITE_FRONTEND_URL=http://localhost:3000
# VITE_MODE=production
# VITE_HUB_API_URL=
# VITE_HUB_OAUTH_REDIRECT_URL=
# VITE_HUB_PROFILE_PIC_API_KEY=

# --- HTTPS / nginx (production-style deploy) ---
# NGINX_BASE_DOMAIN=example.com
# SSL_DOMAIN=app.example.com

# --- Local Postgres container (`docker compose --profile with-db`) ---
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=zipsync

# --- First-run seed (optional) ---
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=admin123

# --- Cognito (Hub token exchange) ---
# AWS_COGNITO_USER_POOL_ID=
# AWS_COGNITO_APP_CLIENT_ID=
# AUTH_ALLOWED_DOMAIN=

