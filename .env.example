# =============================================================================
# This file is for DOCKER only. Copy to .env in REPO ROOT (same folder as
# docker-compose.yml). When you run "docker compose up", only this root .env
# is used; backend and frontend containers do NOT read backend/.env or
# frontend/.env. For local dev without Docker, use backend/.env and
# frontend/.env instead. See DOCKER_DEPLOYMENT.md → "Which .env file is used?"
#
# Optional: create .env.local (gitignored) for machine-specific overrides.
# docker-compose loads .env then .env.local for the db and backend services.
# =============================================================================

# ---------- Database ----------------------------------------------------------
# PRODUCTION: Use Supabase. Set DATABASE_URL to your Supabase connection string
# (Supabase Dashboard → Project Settings → Database).
# Start WITHOUT the local db container so you avoid "role postgres does not exist"
# on an old postgres_data volume:
#   docker compose up -d --build
# (db service uses profile "with-db" only; backend uses Supabase via DATABASE_URL.)
# For a local Postgres container instead:
#   docker compose --profile with-db up -d --build
#
# Example – pooler (recommended for Docker/backend):
# DATABASE_URL=postgresql://postgres.[project-ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
# Example – direct (must include sslmode):
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[project-ref].supabase.co:5432/postgres?sslmode=require
#
DATABASE_URL=

# Docker DB (default in docker-compose): host db inside network, or localhost from host machine
# DATABASE_URL=postgresql://postgres:postgres@db:5432/zipsync
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zipsync
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=zipsync

# ---------- [DOCKER ONLY] Default admin (seed on first backend start) ----------
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=admin@123

# Optional: GitHub username added as collaborator when creating a project (invitation email sent by GitHub).
# If value looks like an email, the part before @ is used as GitHub username.
# GITHUB_DEFAULT_COLLABORATOR=kalrav
#
# GitHub API auth (repo creation, remote diff, etc.) is per-project: set githubUsername and githubToken on each
# project in the app — do not rely on GITHUB_TOKEN / GITHUB_USERNAME in this file for the backend.

# ---------- [DOCKER] Backend env (override in docker-compose or here) ----------
# BASE_URL=http://localhost:5000
# Production with HTTPS: set BASE_URL=https://yourdomain.com so build/live URLs use https
# JWT_SECRET=your-secret-key
# INSTANCE_ROOT=/app
# NGINX_BASE_DOMAIN=localhost
#
# ---------- [DOCKER] HTTPS (optional) ----------
# Set when using Let's Encrypt certs. Certs must exist on host at /etc/letsencrypt/live/<domain>/.
# Backend mounts /etc/letsencrypt and generates nginx SSL config; frontend is served at https://<domain>/, API at https://<domain>/api/
# SSL_DOMAIN=launchpad.yorkdevs.link
#
# ---------- [DOCKER] Project port range (ports come from DB: 8001, 8002, ...) ----------
# Last port to publish from backend (default 8100 = 8001-8100). Increase if you have many projects (e.g. 8999).
# PROJECT_PORT_END=8100

# ---------- [DOCKER ONLY] Frontend build args (baked at image build) ----------
# Rebuild frontend after changing: docker compose build --no-cache frontend
# For HTTPS with SSL_DOMAIN, use https and your domain (e.g. https://launchpad.yorkdevs.link).
VITE_API_URL=http://localhost:5000
VITE_FRONTEND_URL=http://localhost:3000
# Example for HTTPS: VITE_API_URL=https://launchpad.yorkdevs.link  VITE_FRONTEND_URL=https://launchpad.yorkdevs.link
# Matches frontend/src/config (isProduction). Default production for Docker.
# VITE_MODE=production
# VITE_HUB_API_URL=
# VITE_HUB_OAUTH_REDIRECT_URL=
# Optional: Hub profile picture API key (baked into frontend bundle at build).
# VITE_HUB_PROFILE_PIC_API_KEY=

# ---------- Backend (Docker / same root .env) — CORS & OAuth return ----------
# Must be the exact URL users open in the browser (same origin as the SPA) or GitHub/Jira OAuth will
# redirect to the wrong host and you will lose the session or land on /login.
# UAT/prod: https://your-uat-domain.com (no trailing slash)
# Local Docker: http://localhost:3000
# If you omit FRONTEND_URL, the backend uses VITE_FRONTEND_URL when set (same file for Docker builds).
# FRONTEND_URL=http://localhost:3000

# ---------- Cognito (for Hub OAuth → app token exchange) ----------
# When using Hub/Cognito login, backend exchanges Cognito idToken for app JWT.
# User Pool ID (use either name):
#   AWS_COGNITO_USER_POOL_ID=eu-west-1_xxxxx
# App Client ID (Cognito → User Pool → App integration → App clients; use either name):
#   AWS_COGNITO_APP_CLIENT_ID=your-app-client-id
# Region (optional if user pool id has region prefix e.g. eu-west-1_xxx):
#   AWS_COGNITO_REGION=eu-west-1
# Optional: restrict sign-in to domain (e.g. york.ie for *@york.ie)
# AUTH_ALLOWED_DOMAIN=york.ie

# ---------- Frontend: Hub API (OAuth callback + refresh) ----------
# Set in frontend/.env. Frontend config exposes it as HUB_API_URL (single source).
# VITE_HUB_API_URL=https://api.uat-hub.allcloudworks.com
# Hub refresh: POST {HUB_API_URL}/api/auth/refresh with { refreshToken, email }.
# Optional: VITE_DEBUG_REFRESH=true to log refresh in console (dev only).

# ---------- Frontend folder .env (local dev without Docker) ----------
# When running cd frontend && npm run dev, Vite reads frontend/.env only.
# Copy frontend/.env.example to frontend/.env and set VITE_API_URL there.

# ---------- Cursor Cloud Agents (backend) ----------
# Required for client-link chat and /api/cursor. Create a key in the Cursor dashboard.
# CURSOR_API_KEY=
# Optional: force source.ref for Cursor agents. If unset, the ref is read from GitHub default_branch for the repo.
# CURSOR_AGENT_SOURCE_REF=main

# ---------- GitHub & Jira OAuth (backend) — project creation without manual PAT/API tokens ----------
# 32-byte key, base64 (generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
# OAUTH_TOKEN_ENCRYPTION_KEY=
# Optional; defaults to JWT_SECRET if unset (still required for signing OAuth state)
# OAUTH_STATE_SECRET=
# GitHub OAuth App "Authorization callback URL" = backend route (GitHub sends ?code=&state= here)
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_REDIRECT_URI=http://localhost:5000/api/integrations/github/callback
# Optional: GITHUB_OAUTH_SCOPES=repo read:user
# Atlassian 3LO "Callback URL" = same pattern on your API host
# ATLASSIAN_OAUTH_CLIENT_ID=
# ATLASSIAN_OAUTH_CLIENT_SECRET=
# ATLASSIAN_OAUTH_REDIRECT_URI=http://localhost:5000/api/integrations/jira/callback
# Optional: ATLASSIAN_OAUTH_SCOPES=read:jira-user read:jira-work write:jira-work offline_access
#
# Bitbucket OAuth (backend) — OAuth consumer callback URL must match REDIRECT_URI exactly
# BITBUCKET_OAUTH_CLIENT_ID=
# BITBUCKET_OAUTH_CLIENT_SECRET=
# BITBUCKET_OAUTH_REDIRECT_URI=http://localhost:5000/api/integrations/bitbucket/callback
# Optional: BITBUCKET_OAUTH_SCOPES=account repository
