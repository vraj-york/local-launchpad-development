# Frontend local dev – copy to .env in this folder (frontend/)
# Vite only reads env from frontend/ when you run: cd frontend && npm run dev
# Docker builds use repo root .env build args instead (see root .env.example).

# Backend API base URL (browser calls this; must be reachable from the user's machine)
VITE_API_URL=http://localhost:5000

# Optional: frontend origin (redirects, links)
VITE_FRONTEND_URL=http://localhost:5173

# Must be exactly "production" (no spaces) for isProduction in frontend/src/config
VITE_MODE=production

# Optional: profile-pic host if different from VITE_HUB_API_URL (e.g. https://api.hub.york.ie)
# VITE_HUB_PROFILE_PIC_API_URL=

# Hub profile picture — x-api-key header, JSON { url }
# VITE_HUB_PROFILE_PIC_API_KEY=

# AI SVG for Client Link is proxied via the backend; set CLAUDE_API_KEY (or ANTHROPIC_API_KEY) on the server (.env at repo root).