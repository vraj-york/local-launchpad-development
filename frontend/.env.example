# Local Vite — copy to `frontend/.env` (`npm run dev` from `frontend/`). Docker builds use repo-root `.env` instead.

VITE_API_URL=http://localhost:5000

# Optional: frontend origin (redirects, links)
VITE_FRONTEND_URL=http://localhost:5173

# Must be exactly "production" (no spaces) for isProduction in frontend/src/config when you need prod behavior locally
# VITE_MODE=production

# Optional: Hub (defaults exist in src/config for UAT-style URLs)
# VITE_HUB_API_URL=
# VITE_HUB_OAUTH_REDIRECT_URL=
# VITE_HUB_PROFILE_PIC_API_URL=
# VITE_HUB_PROFILE_PIC_API_KEY=

# AI SVG for Client Link is proxied via the backend; set CLAUDE_API_KEY (or ANTHROPIC_API_KEY) on the server (repo root `.env` for Docker, or backend/.env for local API).
