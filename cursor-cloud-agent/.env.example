# Auth token for remote access. If unset, a random token is generated each launch.
# AUTH_TOKEN=my-secret-token

# Workspace path for Cursor. Usually set automatically by the CLI.
# CURSOR_WORKSPACE=/path/to/your/project

# Pass --trust to the agent CLI (skips confirmation prompts).
# CURSOR_TRUST=1

# Server port (default: 3100).
# PORT=3100

# Optional fallback: GitHub PAT when no per-email PAT is stored via POST /api/v0/credentials/github?email=...
# (Per-user PATs are stored encrypted in ~/.cursor-local-remote/sessions.db — see github_credentials table.)
# GITHUB_PAT_TOKEN=ghp_...

# Author for automated `git commit` after cloud agent runs (defaults applied in code if unset).
# GIT_AUTHOR_NAME=Cursor Cloud Agent
# GIT_AUTHOR_EMAIL=cursor-cloud-agent@localhost
