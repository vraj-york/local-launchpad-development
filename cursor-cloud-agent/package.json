{
  "name": "cursor-cloud-api",
  "version": "0.1.15",
  "type": "module",
  "description": "Works like Cursor Cloud API but locally",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/parth-york-ie/cursor-cloud-api.git"
  },
  "keywords": [
    "cursor",
    "cursor-ide",
    "remote",
    "ai",
    "agent",
    "cli",
    "mobile"
  ],
  "bin": {
    "cursor-local-remote": "./bin/cursor-remote.mjs",
    "clr": "./bin/cursor-remote.mjs"
  },
  "files": [
    "bin/",
    "public/",
    ".next/server/",
    ".next/static/",
    ".next/*.json",
    ".next/BUILD_ID",
    ".next/package.json",
    "next.config.mjs"
  ],
  "scripts": {
    "dev": "node bin/dev.mjs",
    "dev:log": "node bin/dev.mjs --log",
    "build": "next build",
    "start": "node bin/dev.mjs --start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build && find .next -name '*.map' -delete"
  },
  "dependencies": {
    "@khmyznikov/pwa-install": "^0.6.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "highlight.js": "^11.11.1",
    "next": "^15.5.12",
    "qrcode-terminal": "^0.12.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sql.js": "^1.14.1",
    "web-haptics": "^0.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.9",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20"
  }
}
