## Production Docker environment (repo root)
## Copy to .env on production server.

# --- Database (production DB only) ---
DATABASE_URL=postgresql://<prod-db-user>:<prod-db-password>@<prod-db-host>:5432/<prod-db-name>?sslmode=require

# --- Backend ---
JWT_SECRET=<generate-strong-random-secret>
BASE_URL=https://app.example.com
FRONTEND_URL=https://app.example.com
NGINX_BASE_DOMAIN=example.com
SSL_DOMAIN=app.example.com

# Optional project preview range end (default is 8100)
PROJECT_PORT_END=8100

# --- Frontend build args ---
VITE_API_URL=https://app.example.com
VITE_FRONTEND_URL=https://app.example.com
VITE_MODE=production

# --- Optional integrations ---
GITHUB_TOKEN=
GITHUB_USERNAME=
CURSOR_API_KEY=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_COGNITO_USER_POOL_ID=
AWS_COGNITO_APP_CLIENT_ID=
AUTH_ALLOWED_DOMAIN=
VITE_HUB_API_URL=
VITE_HUB_OAUTH_REDIRECT_URL=
VITE_HUB_PROFILE_PIC_API_KEY=
