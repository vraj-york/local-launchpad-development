# Production — copy to repo-root `.env` on the server (Docker).

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
JWT_SECRET=
BASE_URL=https://app.example.com
FRONTEND_URL=https://app.example.com
NGINX_BASE_DOMAIN=example.com
SSL_DOMAIN=app.example.com

VITE_API_URL=https://app.example.com
VITE_FRONTEND_URL=https://app.example.com
VITE_MODE=production

# Optional: preview ports 8001–N (default N=8100)
# PROJECT_PORT_END=8100

# --- Optional integrations (see docker-compose.yml) ---
# GitHub API uses per-project tokens in the DB — not env.
# CURSOR_API_KEY=
# CURSOR_AGENT_SOURCE_REF=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_COGNITO_USER_POOL_ID=
# AWS_COGNITO_APP_CLIENT_ID=
# AUTH_ALLOWED_DOMAIN=
# VITE_HUB_API_URL=
# VITE_HUB_OAUTH_REDIRECT_URL=
# VITE_HUB_PROFILE_PIC_API_KEY=
# OAUTH_TOKEN_ENCRYPTION_KEY, GITHUB_OAUTH_*, ATLASSIAN_OAUTH_*, BITBUCKET_OAUTH_*
# GITHUB_PUSH_WEBHOOK_SECRET=
# BITBUCKET_PUSH_WEBHOOK_SECRET=
