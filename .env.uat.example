## UAT Docker environment (repo root)
## Copy to .env on UAT server.

# --- Database (UAT DB only) ---
DATABASE_URL=postgresql://<uat-db-user>:<uat-db-password>@<uat-db-host>:5432/<uat-db-name>?sslmode=require

# --- Backend ---
JWT_SECRET=<generate-strong-random-secret>
BASE_URL=https://uat.example.com
# Same origin as the SPA — required for GitHub/Jira OAuth return (backend redirects browser here after callback).
FRONTEND_URL=https://uat.example.com
NGINX_BASE_DOMAIN=example.com
SSL_DOMAIN=uat.example.com

# Optional project preview range end (default is 8100)
PROJECT_PORT_END=8100

# --- Frontend build args ---
VITE_API_URL=https://uat.example.com
VITE_FRONTEND_URL=https://uat.example.com
VITE_MODE=production

# --- Optional integrations ---
# GitHub API (repo create, diff fallback, etc.) uses per-project githubUsername/githubToken in the DB — not env.
CURSOR_API_KEY=
# Optional: Cursor Cloud agent base Git ref (e.g. main). Unset = per-request ref or repo default branch.
CURSOR_AGENT_SOURCE_REF=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_COGNITO_USER_POOL_ID=
AWS_COGNITO_APP_CLIENT_ID=
AUTH_ALLOWED_DOMAIN=
VITE_HUB_API_URL=
VITE_HUB_OAUTH_REDIRECT_URL=
VITE_HUB_PROFILE_PIC_API_KEY=

# --- GitHub / Jira OAuth (backend) — callback must hit your API host, not localhost ---
# GITHUB_OAUTH_REDIRECT_URI=https://uat.example.com/api/integrations/github/callback
# ATLASSIAN_OAUTH_REDIRECT_URI=https://uat.example.com/api/integrations/jira/callback
# OAUTH_TOKEN_ENCRYPTION_KEY=<base64 32 bytes>
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# ATLASSIAN_OAUTH_CLIENT_ID=
# ATLASSIAN_OAUTH_CLIENT_SECRET=
