# UAT — copy to repo-root `.env` on the server (Docker).

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
JWT_SECRET=
BASE_URL=https://uat.example.com
FRONTEND_URL=https://uat.example.com
NGINX_BASE_DOMAIN=example.com
SSL_DOMAIN=uat.example.com

VITE_API_URL=https://uat.example.com
VITE_FRONTEND_URL=https://uat.example.com
VITE_MODE=production

# Optional: preview ports 8001–N (default N=8100)
# PROJECT_PORT_END=8100

