# UAT — copy to repo-root `.env` on the server (Docker).

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
JWT_SECRET=
BASE_URL=https://uat.example.com
FRONTEND_URL=https://uat.example.com
NGINX_BASE_DOMAIN=example.com
SSL_DOMAIN=uat.example.com

VITE_API_URL=https://uat.example.com
VITE_FRONTEND_URL=https://uat.example.com
VITE_MODE=production

# Optional: preview ports 8001–N (default N=8100)
# PROJECT_PORT_END=8100

# --- GitHub / Jira / Bitbucket OAuth — callback must hit your API host, not localhost ---
# OAUTH_TOKEN_ENCRYPTION_KEY=<base64 32 bytes>
# OAUTH_STATE_SECRET=
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_REDIRECT_URI=https://uat.example.com/api/integrations/github/callback
# ATLASSIAN_OAUTH_CLIENT_ID=
# ATLASSIAN_OAUTH_CLIENT_SECRET=
# ATLASSIAN_OAUTH_REDIRECT_URI=https://uat.example.com/api/integrations/jira/callback
# BITBUCKET_OAUTH_CLIENT_ID=
# BITBUCKET_OAUTH_CLIENT_SECRET=
# BITBUCKET_OAUTH_REDIRECT_URI=https://uat.example.com/api/integrations/bitbucket/callback

# --- SCM push webhooks (Launchpad gitRepoPath) ---
# GITHUB_PUSH_WEBHOOK_SECRET=<openssl rand -hex 32>
# BITBUCKET_PUSH_WEBHOOK_SECRET=<openssl rand -hex 32>

# Optional — Cognito, Hub build, S3, Cursor, OpenAI (see docker-compose.yml for variable names):
# AWS_COGNITO_USER_POOL_ID, AWS_COGNITO_APP_CLIENT_ID, AUTH_ALLOWED_DOMAIN
# VITE_HUB_API_URL, VITE_HUB_OAUTH_REDIRECT_URL, VITE_HUB_PROFILE_PIC_API_KEY
# AWS_REGION, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_S3_BUCKET
# CURSOR_API_KEY, CURSOR_AGENT_SOURCE_REF, OPENAI_API_KEY, OPENAI_MODEL
